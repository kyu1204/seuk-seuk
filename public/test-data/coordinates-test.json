  "testScenarios": [
    {
      "id": "browser-compatibility",
      "name": "브라우저 호환성 테스트",
      "description": "Chrome, Firefox, Safari, Edge에서 동일한 위치 렌더링 확인",
      "expectedBehavior": "모든 브라우저에서 픽셀 단위까지 동일한 위치",
      "tolerancePixels": 1
    },
    {
      "id": "responsive-scaling",
      "name": "반응형 스케일링 테스트",
      "description": "화면 크기 변경 시 상대적 위치 유지 확인",
      "testSizes": [
        { "name": "모바일", "width": 375, "height": 667 },
        { "name": "태블릿", "width": 768, "height": 1024 },
        { "name": "데스크톱", "width": 1920, "height": 1080 }
      ],
      "expectedBehavior": "화면 크기와 관계없이 동일한 상대적 위치"
    },
    {
      "id": "zoom-stability",
      "name": "줌 레벨 안정성 테스트",
      "description": "브라우저 확대/축소 시 위치 정확성 확인",
      "zoomLevels": [0.5, 0.75, 1.0, 1.25, 1.5, 2.0],
      "expectedBehavior": "줌 레벨과 관계없이 정확한 상대적 위치"
    },
    {
      "id": "image-ratio-test",
      "name": "이미지 비율 테스트",
