  "validationRules": {
    "coordinateRange": {
      "min": 0,
      "max": 1,
      "description": "모든 좌표값은 0-1 범위 내"
    },
    "minimumSize": {
      "width": 0.01,
      "height": 0.01,
      "description": "최소 1% 크기 권장"
    },
    "maximumSize": {
      "width": 0.5,
      "height": 0.5,
      "description": "최대 50% 크기 권장"
    },
    "boundary": {
      "description": "x + width ≤ 1, y + height ≤ 1"
    },
    "pixelTolerance": 1,
    "description": "변환 시 최대 1픽셀 오차 허용"
  }
