        { "name": "초광각", "ratio": "21:9" },
        { "name": "와이드", "ratio": "16:9" },
        { "name": "표준", "ratio": "4:3" },
        { "name": "정사각형", "ratio": "1:1" },
        { "name": "세로", "ratio": "3:4" },
        { "name": "길쭉함", "ratio": "9:16" }
      ],
      "expectedBehavior": "이미지 비율과 관계없이 정확한 상대적 위치"
    }
